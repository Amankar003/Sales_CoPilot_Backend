# ============================================
# LeadPilot AI - Environment Configuration
# ============================================

# Database
DATABASE_URL=sqlite:///./leadpilot.db

# Groq LLM Configuration (optional - mock responses used if missing)
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_HEAVY_MODEL=llama-3.3-70b-versatile
GROQ_LIGHT_MODEL=llama-3.1-8b-instant

# SMTP Email (optional - email disabled if missing)
SMTP_HOST=
SMTP_PORT=587
SMTP_EMAIL=
SMTP_PASSWORD=

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
